PORT=3001
NODE_ENV=development

# TEMP: timing por request (totalMs/prismaMs/prismaCount) + log de cada query Prisma
# PERF_LOG=true

# Obrigatório (mín. 32 chars). Sem isso o app não sobe.
JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origem do front (usado no CORS quando não houver proxy)
CORS_ORIGIN=http://localhost:3000

# URL pública do front (links de e-mail, ex.: recuperação de senha)
APP_URL=http://localhost:3000

# Resend (e-mails transacionais)
RESEND_API_KEY=
# Com domínio verificado no Resend:
RESEND_FROM_EMAIL=MinhaChurch <nao-responda@send.minhachurch.com>
# Sem domínio verificado (só envia para o e-mail da sua conta Resend):
# RESEND_FROM_EMAIL=MinhaChurch <onboarding@resend.dev>

# Trial / paywall
# Em produção: TRIAL_ENFORCEMENT=true
TRIAL_ENFORCEMENT=false
TRIAL_DURATION_DAYS=30

# Onboarding / e-mail
# EMAIL_VERIFICATION_REQUIRED=true exige confirmação de e-mail para proprietários
EMAIL_VERIFICATION_REQUIRED=false
# ENFORCE_CANONICAL_EMAIL=false permite aliases Gmail (+tag) em dev
ENFORCE_CANONICAL_EMAIL=false

# Stripe
# Desenvolvimento: chaves de teste (sk_test_..., pk_test_..., whsec_... do `stripe listen`)
# Produção:
#   1. Crie os 8 preços (mensal/anual × 4 faixas) no Dashboard Stripe (modo live)
#   2. Configure o webhook: POST https://<sua-api>/api/v1/billing/webhook
#      Eventos mínimos: checkout.session.completed, customer.subscription.updated,
#      customer.subscription.deleted, invoice.payment_failed
#   E-mails transacionais de billing (confirmação, falha, cancelamento) usam RESEND_*.
#   3. Use STRIPE_WEBHOOK_SECRET do endpoint live (diferente do CLI local)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SMALL_MONTHLY=
STRIPE_PRICE_SMALL_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_CONSOLIDATED_MONTHLY=
STRIPE_PRICE_CONSOLIDATED_YEARLY=
STRIPE_PRICE_MULTI_MONTHLY=
STRIPE_PRICE_MULTI_YEARLY=

# Stripe Connect (recebimentos da igreja — dízimo/doações/eventos)
# Webhook DEDICADO do Connect (secret diferente do billing acima):
#   POST https://<sua-api>/api/v1/payments/connect/webhook
#   Eventos mínimos: account.updated, capability.updated,
#     payment_intent.succeeded, payment_intent.payment_failed,
#     payment_intent.processing, payment_intent.canceled
#   No `stripe listen` local, use --forward-to e --forward-connect-to:
#     stripe listen --forward-to localhost:3001/api/v1/billing/webhook \
#       --forward-connect-to localhost:3001/api/v1/payments/connect/webhook
STRIPE_CONNECT_WEBHOOK_SECRET=
# Taxa da plataforma por transação em basis points (100 = 1%). Lançamento: 0.
PAYMENTS_PLATFORM_FEE_BPS=0
# Métodos habilitados (capabilities solicitadas nas contas conectadas).
PAYMENTS_ENABLED_METHODS=pix,card,boleto

# Neon PostgreSQL (Connection string do painel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
