PORT=3001
NODE_ENV=development

JWT_SECRET=dev-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origem do front (usado no CORS quando não houver proxy)
CORS_ORIGIN=http://localhost:3000

# URL pública do front (links de e-mail, ex.: recuperação de senha)
APP_URL=http://localhost:3000

# Resend (e-mails transacionais)
RESEND_API_KEY=
# Com domínio verificado no Resend:
RESEND_FROM_EMAIL=MinhaChurch <nao-responda@send.minhachurch.com>
# Sem domínio verificado (só envia para o e-mail da sua conta Resend):
# RESEND_FROM_EMAIL=MinhaChurch <onboarding@resend.dev>

# Onboarding / anti-abuso
# --- Perfil A: dev rápido (aliases + sem verificação) ---
# ENFORCE_CANONICAL_EMAIL=false
# EMAIL_VERIFICATION_REQUIRED=false
# --- Perfil B: dev com fluxo completo (aliases + verificação Resend) ---
ENFORCE_CANONICAL_EMAIL=false
EMAIL_VERIFICATION_REQUIRED=true
# --- Produção (NODE_ENV=production): padrão true/true se omitido ---
# ENFORCE_CANONICAL_EMAIL=true
# EMAIL_VERIFICATION_REQUIRED=true
UNVERIFIED_MEMBER_LIMIT=5

# Neon PostgreSQL (Connection string do painel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
