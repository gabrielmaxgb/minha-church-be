generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChurchPermission {
  dashboard_access
  members_access
  ministries_access
  activities_access
  schedules_access
  members_manage
  ministries_manage
  events_create_church_wide
  finances_access
  communication_access
  reports_access
  settings_access
  roles_manage
  memberships_manage
  communication_manage
  counseling_receive
  receivables_manage
}

enum CareRequestType {
  counseling
  visit
}

enum CareRequestStatus {
  pending
  viewed
}

enum AnnouncementPriority {
  normal
  important
  urgent
}

enum AnnouncementAudienceType {
  church_wide
  ministries
}

enum ChurchPlanTier {
  starter
  small
  growth
  consolidated
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum MemberStatus {
  visitor
  active
  inactive
}

enum Gender {
  male
  female
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
}

enum PasswordResetRequestStatus {
  pending
  resolved
}

enum NotificationType {
  registration_open
  schedule_roster_assigned
  account_linked
  pending_access
}

enum EventRecurrenceFrequency {
  daily
  weekly
  monthly
  yearly
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailCanonical       String    @unique @map("email_canonical")
  cpf                  String?   @unique
  passwordHash         String    @map("password_hash")
  name                 String
  avatarUrl            String?   @map("avatar_url")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  temporaryPasswordEnc String?   @map("temporary_password_enc")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  /// Soft-delete de conta; purge/anonimização após retenção operacional.
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  memberships                   ChurchMembership[]
  memberProfiles                Member[]
  parentalConsentsRecorded      Member[]           @relation("ParentalConsentRecordedBy")
  ministryEvents                MinistryEvent[]    @relation("EventCreatedBy")
  auditLogs                     AuditLog[]
  passwordResetTokens           PasswordResetToken[]
  emailVerificationTokens       EmailVerificationToken[]
  passwordResetRequests         PasswordResetRequest[]
  resolvedPasswordResetRequests PasswordResetRequest[] @relation("ResolvedPasswordResetRequests")
  announcements                 Announcement[]     @relation("AnnouncementAuthor")
  announcementReads             AnnouncementRead[]
  billingTierUpgradeAcknowledgments BillingTierUpgradeAcknowledgment[]
  billingTierUpgradeRequestsMade    BillingTierUpgradeRequest[]        @relation("BillingTierUpgradeRequestedBy")
  billingTierUpgradeRequestsResolved BillingTierUpgradeRequest[]       @relation("BillingTierUpgradeResolvedBy")
  billingTierUpgradeStaffNoticeReads BillingTierUpgradeStaffNoticeRead[]
  financeEntriesCreated            FinanceEntry[] @relation("FinanceEntryCreatedBy")
  notifications                    Notification[]     @relation("NotificationRecipient")
  notificationReads                NotificationRead[]
  legalAcceptances              LegalAcceptance[]

  @@index([deletedAt])
  @@map("users")
}

model Church {
  id                     String               @id @default(cuid())
  name                   String
  slug                   String               @unique
  memberCount            Int                  @default(0) @map("member_count")
  planTier               ChurchPlanTier         @default(starter) @map("plan_tier")
  subscriptionStatus     SubscriptionStatus   @default(trialing) @map("subscription_status")
  trialEndsAt            DateTime?            @map("trial_ends_at")
  stripeCustomerId       String?              @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?              @map("stripe_subscription_id")
  stripePriceId          String?              @map("stripe_price_id")
  cancelAtPeriodEnd      Boolean              @default(false) @map("cancel_at_period_end")
  pastDueSince           DateTime?            @map("past_due_since")
  /// Aceite do Adendo LGPD (DPA) pelo owner.
  dpaAcceptedAt          DateTime?            @map("dpa_accepted_at")
  dpaVersion             String?              @map("dpa_version")
  /// Encerramento solicitado; acesso bloqueado até cancelar ou purge.
  deletedAt              DateTime?            @map("deleted_at")
  /// Data em que o job de retenção pode anonimizar o tenant.
  purgeAfter             DateTime?            @map("purge_after")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  memberships           ChurchMembership[]
  members               Member[]
  families              Family[]
  memberRelations       MemberRelation[]
  ministries            Ministry[]
  roles                 ChurchRole[]
  auditLogs             AuditLog[]
  passwordResetRequests PasswordResetRequest[]
  announcements         Announcement[]
  careRequests          CareRequest[]
  prayerRequests        PrayerRequest[]

  billingTierUpgradeAcknowledgments BillingTierUpgradeAcknowledgment[]
  billingTierUpgradeRequests        BillingTierUpgradeRequest[]
  billingTierUpgradeStaffNotices    BillingTierUpgradeStaffNotice[]

  fiscalProfile        ChurchFiscalProfile?
  paymentAccount       ChurchPaymentAccount?
  givingFunds          GivingFund[]
  givingDonations      GivingDonation[]
  givingSubscriptions  GivingSubscription[]
  financeEntries       FinanceEntry[]
  eventTicketPurchases EventTicketPurchase[]
  notifications        Notification[]
  legalAcceptances     LegalAcceptance[]

  @@index([deletedAt])
  @@index([purgeAfter])
  @@map("churches")
}

enum LegalDocumentType {
  terms
  privacy
  dpa
}

/// Registro de aceite de documentos legais (termos, privacidade, DPA).
model LegalAcceptance {
  id           String            @id @default(cuid())
  churchId     String            @map("church_id")
  userId       String            @map("user_id")
  documentType LegalDocumentType @map("document_type")
  version      String
  acceptedAt   DateTime          @default(now()) @map("accepted_at")
  ip           String?

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([churchId, documentType])
  @@index([userId])
  @@map("legal_acceptances")
}

model BillingTierUpgradeAcknowledgment {
  id        String   @id @default(cuid())
  churchId  String   @map("church_id")
  tierId    String   @map("tier_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, tierId])
  @@map("billing_tier_upgrade_acknowledgments")
}

enum BillingTierUpgradeRequestStatus {
  pending
  approved
  dismissed
}

model BillingTierUpgradeRequest {
  id               String                          @id @default(cuid())
  churchId         String                          @map("church_id")
  targetTierId     String                          @map("target_tier_id")
  requestedByUserId String                         @map("requested_by_user_id")
  status           BillingTierUpgradeRequestStatus @default(pending)
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  resolvedAt       DateTime?                       @map("resolved_at")
  resolvedByUserId String?                         @map("resolved_by_user_id")

  church      Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  requestedBy User   @relation("BillingTierUpgradeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  resolvedBy  User?  @relation("BillingTierUpgradeResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([churchId, targetTierId])
  @@index([churchId, status])
  @@map("billing_tier_upgrade_requests")
}

model BillingTierUpgradeStaffNotice {
  id        String   @id @default(cuid())
  churchId  String   @map("church_id")
  tierId    String   @map("tier_id")
  createdAt DateTime @default(now()) @map("created_at")

  church Church                            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  reads  BillingTierUpgradeStaffNoticeRead[]

  @@index([churchId, createdAt])
  @@map("billing_tier_upgrade_staff_notices")
}

model BillingTierUpgradeStaffNoticeRead {
  id       String   @id @default(cuid())
  noticeId String   @map("notice_id")
  userId   String   @map("user_id")
  readAt   DateTime @default(now()) @map("read_at")

  notice BillingTierUpgradeStaffNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@map("billing_tier_upgrade_staff_notice_reads")
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_webhook_events")
}

enum ChurchDocumentType {
  cnpj
  cpf
}

enum ConnectOnboardingStatus {
  none
  created
  onboarding
  verifying
  active
  restricted
  rejected
}

enum ConnectCapabilityStatus {
  inactive
  pending
  active
}

enum GivingDonationStatus {
  pending
  processing
  succeeded
  failed
  canceled
  refunded
}

enum GivingFundAudience {
  members
  public
}

enum GivingSubscriptionStatus {
  incomplete
  active
  past_due
  canceled
}

enum EventTicketStatus {
  pending
  succeeded
  failed
  canceled
  refunded
}

enum FinanceEntryType {
  income
  expense
}

enum FinanceEntryMethod {
  cash
  transfer
  other
}

/// Perfil fiscal/legal da igreja (identidade para NF, contrato e prefill do Connect).
model ChurchFiscalProfile {
  id                  String             @id @default(cuid())
  churchId            String             @unique @map("church_id")
  documentType        ChurchDocumentType @map("document_type")
  documentNumber      String             @map("document_number")
  legalName           String             @map("legal_name")
  responsibleName     String             @map("responsible_name")
  responsibleDocument String?            @map("responsible_document")
  addressLine         String?            @map("address_line")
  city                String?
  state               String?
  zipCode             String?            @map("zip_code")
  contactEmail        String?            @map("contact_email")
  contactPhone        String?            @map("contact_phone")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@map("church_fiscal_profiles")
}

/// Estado da conta conectada (Stripe Connect Express) da igreja, sincronizado por webhook.
model ChurchPaymentAccount {
  id               String                  @id @default(cuid())
  churchId         String                  @unique @map("church_id")
  stripeAccountId  String?                 @unique @map("stripe_account_id")
  accountType      String                  @default("express") @map("account_type")
  onboardingStatus ConnectOnboardingStatus @default(none) @map("onboarding_status")
  chargesEnabled   Boolean                 @default(false) @map("charges_enabled")
  payoutsEnabled   Boolean                 @default(false) @map("payouts_enabled")
  detailsSubmitted Boolean                 @default(false) @map("details_submitted")
  pixStatus        ConnectCapabilityStatus @default(inactive) @map("pix_status")
  cardStatus       ConnectCapabilityStatus @default(inactive) @map("card_status")
  boletoStatus     ConnectCapabilityStatus @default(inactive) @map("boleto_status")
  requirementsDue  Json?                   @map("requirements_due")
  disabledReason   String?                 @map("disabled_reason")
  lastSyncedAt     DateTime?               @map("last_synced_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@map("church_payment_accounts")
}

/// Idempotência de webhooks do Stripe Connect (separado do billing SaaS).
model ConnectWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("connect_webhook_events")
}

/// Categoria de cobrança da igreja (dízimo, oferta, campanha, etc.).
model GivingFund {
  id          String             @id @default(cuid())
  churchId    String             @map("church_id")
  name        String
  slug        String
  description String?
  audience    GivingFundAudience @default(members)
  allowPix    Boolean            @default(true) @map("allow_pix")
  allowCard   Boolean            @default(true) @map("allow_card")
  allowBoleto Boolean            @default(true) @map("allow_boleto")
  isActive    Boolean            @default(true) @map("is_active")
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  church         Church                @relation(fields: [churchId], references: [id], onDelete: Cascade)
  donations      GivingDonation[]
  subscriptions  GivingSubscription[]
  financeEntries FinanceEntry[]

  @@unique([churchId, slug])
  @@index([churchId, isActive])
  @@index([churchId, audience, isActive])
  @@map("giving_funds")
}

/// Assinatura de contribuição recorrente (Stripe Subscription na conta conectada).
model GivingSubscription {
  id                   String                    @id @default(cuid())
  churchId             String                    @map("church_id")
  fundId               String                    @map("fund_id")
  donorMemberId        String?                   @map("donor_member_id")
  stripeSubscriptionId String                    @unique @map("stripe_subscription_id")
  stripeCustomerId     String?                   @map("stripe_customer_id")
  amountCents          Int                       @map("amount_cents")
  currency             String                    @default("brl")
  status               GivingSubscriptionStatus  @default(incomplete)
  payerName            String?                   @map("payer_name")
  payerEmail           String?                   @map("payer_email")
  canceledAt           DateTime?                 @map("canceled_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  church      Church           @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fund        GivingFund       @relation(fields: [fundId], references: [id], onDelete: Restrict)
  donorMember Member?          @relation(fields: [donorMemberId], references: [id], onDelete: SetNull)
  donations   GivingDonation[]

  @@index([churchId, status])
  @@index([donorMemberId])
  @@map("giving_subscriptions")
}

/// Doação/contribuição recebida via Stripe Connect (direct charge).
/// Fundos com pelo menos um registro não podem ser excluídos — só desativados.
model GivingDonation {
  id                    String               @id @default(cuid())
  churchId              String               @map("church_id")
  fundId                String               @map("fund_id")
  donorMemberId         String?              @map("donor_member_id")
  subscriptionId        String?              @map("subscription_id")
  stripePaymentIntentId String?              @unique @map("stripe_payment_intent_id")
  amountCents           Int                  @map("amount_cents")
  currency              String               @default("brl")
  status                GivingDonationStatus @default(pending)
  payerName             String?              @map("payer_name")
  payerEmail            String?              @map("payer_email")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  church       Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fund         GivingFund          @relation(fields: [fundId], references: [id], onDelete: Restrict)
  donorMember  Member?             @relation(fields: [donorMemberId], references: [id], onDelete: SetNull)
  subscription GivingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([churchId, createdAt])
  @@index([fundId])
  @@index([donorMemberId])
  @@index([subscriptionId])
  @@map("giving_donations")
}

/// Lançamento manual no livro-caixa (entrada ou saída).
model FinanceEntry {
  id              String             @id @default(cuid())
  churchId        String             @map("church_id")
  type            FinanceEntryType
  amountCents     Int                @map("amount_cents")
  currency        String             @default("brl")
  occurredOn      DateTime           @map("occurred_on") @db.Date
  category        String
  fundId          String?            @map("fund_id")
  method          FinanceEntryMethod @default(other)
  note            String?
  createdByUserId String?            @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  church    Church      @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fund      GivingFund? @relation(fields: [fundId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("FinanceEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([churchId, occurredOn])
  @@map("finance_entries")
}

model ChurchRole {
  id           String   @id @default(cuid())
  churchId     String   @map("church_id")
  name         String
  color        String?
  sortOrder    Int      @default(0) @map("sort_order")
  isSystem     Boolean  @default(false) @map("is_system")
  systemKey    String?  @map("system_key")
  singleHolder Boolean  @default(false) @map("single_holder")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  church      Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  permissions ChurchRolePermission[]
  assignments ChurchMembershipRole[]

  @@unique([churchId, name])
  @@unique([churchId, systemKey])
  @@map("church_roles")
}

model ChurchRolePermission {
  roleId     String           @map("role_id")
  permission ChurchPermission

  role ChurchRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("church_role_permissions")
}

model ChurchMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  churchId  String   @map("church_id")
  isOwner   Boolean  @default(false) @map("is_owner")
  createdAt DateTime @default(now()) @map("created_at")

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church          Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  roleAssignments ChurchMembershipRole[]

  @@unique([userId, churchId])
  @@map("church_memberships")
}

model ChurchMembershipRole {
  membershipId String   @map("membership_id")
  roleId       String   @map("role_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  membership ChurchMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       ChurchRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("church_membership_roles")
}

model Family {
  id        String   @id @default(cuid())
  churchId  String   @map("church_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  church  Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  members Member[]

  @@unique([churchId, name])
  @@index([churchId])
  @@map("families")
}

model Member {
  id                 String         @id @default(cuid())
  churchId           String         @map("church_id")
  familyId           String?        @map("family_id")
  name               String
  email              String?
  cpf                String?
  phone              String?
  phoneSecondary     String?        @map("phone_secondary")
  birthDate          DateTime?      @map("birth_date") @db.Date
  gender             Gender?
  maritalStatus      MaritalStatus? @map("marital_status")
  weddingAnniversary DateTime?      @map("wedding_anniversary") @db.Date
  street             String?
  number             String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  zipCode            String?        @map("zip_code")
  status             MemberStatus   @default(visitor)
  visitorSince       DateTime?      @map("visitor_since") @db.Date
  baptismDate        DateTime?      @map("baptism_date") @db.Date
  membershipDate     DateTime?      @map("membership_date") @db.Date
  userId             String?        @map("user_id")
  /// Consentimento parental (MVP): preenchido quando menor de 18 tem acesso liberado.
  parentalConsentAt               DateTime? @map("parental_consent_at")
  parentalConsentByUserId         String?   @map("parental_consent_by_user_id")
  parentalConsentGuardianMemberId String?   @map("parental_consent_guardian_member_id")
  parentalConsentGuardianName     String?   @map("parental_consent_guardian_name")
  parentalConsentGuardianEmail    String?   @map("parental_consent_guardian_email")
  parentalConsentVersion          String?   @map("parental_consent_version")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  church         Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  family         Family?             @relation(fields: [familyId], references: [id], onDelete: SetNull)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentalConsentByUser User?        @relation("ParentalConsentRecordedBy", fields: [parentalConsentByUserId], references: [id], onDelete: SetNull)
  parentalConsentGuardian Member?    @relation("ParentalConsentGuardian", fields: [parentalConsentGuardianMemberId], references: [id], onDelete: SetNull)
  parentalConsentWards Member[]      @relation("ParentalConsentGuardian")
  ministryLinks  MemberMinistry[]
  availabilities EventAvailability[]
  eventRoleProfiles MemberEventRoleProfile[]
  rosterAssignments EventRosterAssignment[]
  relationsFrom  MemberRelation[]    @relation("RelationFrom")
  relationsTo    MemberRelation[]    @relation("RelationTo")
  careRequestsSent     CareRequest[] @relation("CareRequestRequester")
  careRequestsReceived CareRequest[] @relation("CareRequestRecipient")
  prayerRequests       PrayerRequest[]
  prayerReactions        PrayerRequestPrayer[]
  givingDonations        GivingDonation[]
  givingSubscriptions    GivingSubscription[]
  eventTicketPurchases   EventTicketPurchase[]

  @@unique([churchId, email])
  @@unique([churchId, cpf])
  @@unique([churchId, userId])
  @@index([churchId, status])
  @@index([churchId, familyId])
  @@index([deletedAt])
  @@map("members")
}

model PrayerRequest {
  id             String    @id @default(cuid())
  churchId       String    @map("church_id")
  authorMemberId String    @map("author_member_id")
  body           String
  isAnonymous    Boolean   @default(false) @map("is_anonymous")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  archivedAt     DateTime? @map("archived_at")
  deletedAt      DateTime? @map("deleted_at")

  church  Church               @relation(fields: [churchId], references: [id], onDelete: Cascade)
  author  Member               @relation(fields: [authorMemberId], references: [id], onDelete: Cascade)
  prayers PrayerRequestPrayer[]

  @@index([churchId, deletedAt, archivedAt, createdAt])
  @@index([authorMemberId])
  @@map("prayer_requests")
}

model PrayerRequestPrayer {
  id              String   @id @default(cuid())
  prayerRequestId String   @map("prayer_request_id")
  memberId        String   @map("member_id")
  createdAt       DateTime @default(now()) @map("created_at")

  prayerRequest PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)
  member        Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([prayerRequestId, memberId])
  @@index([memberId])
  @@map("prayer_request_prayers")
}

model CareRequest {
  id                      String            @id @default(cuid())
  churchId                String            @map("church_id")
  type                    CareRequestType
  requesterMemberId       String            @map("requester_member_id")
  recipientMemberId       String            @map("recipient_member_id")
  message                 String?
  status                  CareRequestStatus @default(pending)
  viewedAt                DateTime?         @map("viewed_at")
  viewNotificationAckedAt DateTime?         @map("view_notification_acked_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  church    Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  requester Member @relation("CareRequestRequester", fields: [requesterMemberId], references: [id], onDelete: Cascade)
  recipient Member @relation("CareRequestRecipient", fields: [recipientMemberId], references: [id], onDelete: Cascade)

  @@index([churchId, recipientMemberId, status])
  @@index([churchId, requesterMemberId, status])
  @@map("care_requests")
}

enum MemberRelationType {
  spouse
  parent
  sibling
  grandparent
  step_parent
  parent_in_law
  uncle
}

model MemberRelation {
  id           String             @id @default(cuid())
  churchId     String             @map("church_id")
  fromMemberId String             @map("from_member_id")
  toMemberId   String             @map("to_member_id")
  type         MemberRelationType
  createdAt    DateTime           @default(now()) @map("created_at")

  church     Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fromMember Member @relation("RelationFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMember   Member @relation("RelationTo", fields: [toMemberId], references: [id], onDelete: Cascade)

  @@unique([fromMemberId, toMemberId, type])
  @@index([churchId])
  @@index([toMemberId])
  @@map("member_relations")
}

enum EventAvailabilityStatus {
  available
  unavailable
}

enum WorshipAvailabilityPeriod {
  weekly
  monthly
  quarterly
  semiannual
  annual
}

model Ministry {
  id          String            @id @default(cuid())
  churchId    String            @map("church_id")
  name        String
  description String?
  hasRoster   Boolean           @default(false) @map("has_roster")
  isActive    Boolean           @default(true) @map("is_active")
  availabilityWindowActive Boolean                   @default(false) @map("availability_window_active")
  availabilityPeriodType   WorshipAvailabilityPeriod? @map("availability_period_type")
  availabilityPeriodStart  DateTime?                  @map("availability_period_start") @db.Date
  availabilityPeriodEnd    DateTime?                  @map("availability_period_end") @db.Date
  serviceFunctionsUpdatedAt DateTime                  @default(now()) @map("service_functions_updated_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  church  Church           @relation(fields: [churchId], references: [id], onDelete: Cascade)
  roles   MinistryRole[]
  members MemberMinistry[]
  events  MinistryEvent[]
  eventRoleProfiles MemberEventRoleProfile[]
  serviceFunctions MinistryServiceFunction[]
  announcementTargets AnnouncementMinistry[]

  @@unique([churchId, name])
  @@map("ministries")
}

model MinistryServiceFunction {
  id         String   @id @default(cuid())
  ministryId String   @map("ministry_id")
  label      String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([ministryId, label])
  @@index([ministryId])
  @@map("ministry_service_functions")
}

model MemberEventRoleProfile {
  id         String   @id @default(cuid())
  memberId   String   @map("member_id")
  ministryId String   @map("ministry_id")
  profileKey String   @map("profile_key")
  roleLabels String[] @default([]) @map("role_labels")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([memberId, ministryId, profileKey])
  @@index([memberId])
  @@map("member_event_role_profiles")
}

model MinistryRole {
  id              String   @id @default(cuid())
  ministryId      String   @map("ministry_id")
  name            String
  sortOrder       Int      @default(0) @map("sort_order")
  canManageEvents Boolean  @default(false) @map("can_manage_events")
  canManageRoster Boolean  @default(false) @map("can_manage_roster")
  canManageTeam   Boolean  @default(false) @map("can_manage_team")
  canManageRoles  Boolean  @default(false) @map("can_manage_roles")
  singleHolder    Boolean  @default(false) @map("single_holder")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  ministry    Ministry         @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  roleAssignments MemberMinistryRole[]

  @@unique([ministryId, name])
  @@map("ministry_roles")
}

model MemberMinistryRole {
  memberMinistryId String   @map("member_ministry_id")
  ministryRoleId   String   @map("ministry_role_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")

  memberMinistry MemberMinistry @relation(fields: [memberMinistryId], references: [id], onDelete: Cascade)
  ministryRole   MinistryRole   @relation(fields: [ministryRoleId], references: [id], onDelete: Cascade)

  @@id([memberMinistryId, ministryRoleId])
  @@map("member_ministry_roles")
}

model MemberMinistry {
  id          String    @id @default(cuid())
  memberId    String    @map("member_id")
  ministryId  String    @map("ministry_id")
  instruments String[]  @default([])
  startedAt   DateTime? @map("started_at") @db.Date
  endedAt     DateTime? @map("ended_at") @db.Date
  serviceFunctionsCatalogSeenAt DateTime? @map("service_functions_catalog_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  member          Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry        Ministry             @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  roleAssignments MemberMinistryRole[]

  @@unique([memberId, ministryId])
  @@map("member_ministries")
}

model EventRecurrenceSeries {
  id             String                   @id @default(cuid())
  churchId       String                   @map("church_id")
  ministryId     String?                  @map("ministry_id")
  frequency      EventRecurrenceFrequency
  interval       Int                      @default(1)
  daysOfWeek     Int[]                    @map("days_of_week")
  endDate        DateTime?                @map("end_date") @db.Date
  maxOccurrences Int?                     @map("max_occurrences")
  createdAt      DateTime                 @default(now()) @map("created_at")

  events MinistryEvent[]

  @@index([churchId])
  @@map("event_recurrence_series")
}

model MinistryEvent {
  id                   String    @id @default(cuid())
  churchId             String    @map("church_id")
  ministryId           String?   @map("ministry_id")
  name                 String
  description          String?
  highlightNote        String?   @map("highlight_note")
  availabilityMessage  String?   @map("availability_message")
  location             String?
  startsAt             DateTime  @map("starts_at")
  endsAt               DateTime? @map("ends_at")
  createdByUserId      String?   @map("created_by_user_id")
  recurrenceSeriesId   String?   @map("recurrence_series_id")
  usesRoster           Boolean   @default(true) @map("uses_roster")
  rosterOpen           Boolean   @default(false) @map("roster_open")
  visibleToChurch      Boolean   @default(true) @map("visible_to_church")
  /// Quando true, membros podem se inscrever (gratuito se priceCents for null).
  registrationOpen     Boolean   @default(false) @map("registration_open")
  /// Preço da inscrição em centavos; null = inscrição gratuita (quando registrationOpen).
  priceCents           Int?      @map("price_cents")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  ministry         Ministry?              @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy        User?                  @relation("EventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  recurrenceSeries EventRecurrenceSeries? @relation(fields: [recurrenceSeriesId], references: [id], onDelete: SetNull)
  availabilities   EventAvailability[]
  rosterSlots      EventRosterSlot[]
  rosterAssignments EventRosterAssignment[]
  ticketPurchases  EventTicketPurchase[]

  @@index([churchId, ministryId, startsAt])
  @@index([churchId, startsAt])
  @@index([recurrenceSeriesId])
  @@map("ministry_events")
}

model EventAvailability {
  id         String                  @id @default(cuid())
  eventId    String                  @map("event_id")
  memberId   String                  @map("member_id")
  status     EventAvailabilityStatus
  roleLabels String[]                @default([]) @map("role_labels")
  createdAt  DateTime                @default(now()) @map("created_at")
  updatedAt  DateTime                @updatedAt @map("updated_at")

  event  MinistryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([memberId])
  @@map("event_availabilities")
}

model EventRosterSlot {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  label         String
  requiredCount Int      @default(1) @map("required_count")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  event       MinistryEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments EventRosterAssignment[]

  @@unique([eventId, label])
  @@index([eventId])
  @@map("event_roster_slots")
}

model EventRosterAssignment {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  memberId     String   @map("member_id")
  rosterSlotId String?  @map("roster_slot_id")
  roleLabel    String   @map("role_label")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event      MinistryEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rosterSlot EventRosterSlot? @relation(fields: [rosterSlotId], references: [id], onDelete: SetNull)

  @@unique([eventId, memberId])
  @@index([eventId, rosterSlotId])
  @@index([memberId])
  @@map("event_roster_assignments")
}

/// Pagamento de inscrição em evento (direct charge na conta Connect).
model EventTicketPurchase {
  id                    String           @id @default(cuid())
  churchId              String           @map("church_id")
  eventId               String           @map("event_id")
  memberId              String?          @map("member_id")
  stripePaymentIntentId String?          @unique @map("stripe_payment_intent_id")
  amountCents           Int              @map("amount_cents")
  currency              String           @default("brl")
  status                EventTicketStatus @default(pending)
  buyerName             String?          @map("buyer_name")
  buyerEmail            String?          @map("buyer_email")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  church Church        @relation(fields: [churchId], references: [id], onDelete: Cascade)
  event  MinistryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member?       @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([churchId, eventId])
  @@index([eventId, status])
  @@index([memberId])
  @@map("event_ticket_purchases")
}

/// Unique parcial: no máximo uma inscrição confirmada por membro/evento.
/// Criada em migration SQL (Prisma não modela índices parciais).

model AuditLog {
  id          String   @id @default(cuid())
  churchId    String   @map("church_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([churchId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([churchId, action])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/** Denylist de refresh JWT por jti (logout / rotação). */
model RevokedRefreshToken {
  jti       String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("revoked_refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetRequest {
  id               String                     @id @default(cuid())
  userId           String                     @map("user_id")
  churchId         String                     @map("church_id")
  status           PasswordResetRequestStatus @default(pending)
  createdAt        DateTime                   @default(now()) @map("created_at")
  resolvedAt       DateTime?                  @map("resolved_at")
  resolvedByUserId String?                    @map("resolved_by_user_id")

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church     Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  resolvedBy User?  @relation("ResolvedPasswordResetRequests", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([churchId, status])
  @@index([userId, churchId, status])
  @@map("password_reset_requests")
}

model Announcement {
  id              String                   @id @default(cuid())
  churchId        String                   @map("church_id")
  title           String
  body            String
  priority        AnnouncementPriority     @default(normal)
  audienceType    AnnouncementAudienceType @default(church_wide) @map("audience_type")
  pinned          Boolean                  @default(false)
  publishedAt     DateTime?                @map("published_at")
  expiresAt       DateTime?                @map("expires_at")
  createdByUserId String?                  @map("created_by_user_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  deletedAt       DateTime?                @map("deleted_at")

  church     Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdBy  User?                  @relation("AnnouncementAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  ministries AnnouncementMinistry[]
  reads      AnnouncementRead[]

  @@index([churchId, deletedAt, publishedAt])
  @@map("announcements")
}

model AnnouncementMinistry {
  announcementId String @map("announcement_id")
  ministryId     String @map("ministry_id")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  ministry     Ministry     @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@id([announcementId, ministryId])
  @@index([ministryId])
  @@map("announcement_ministries")
}

model AnnouncementRead {
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@index([userId])
  @@map("announcement_reads")
}

/// Inbox unificado in-app (1ª leva). Itens pessoais usam userId + readAt;
/// itens compartilhados de staff usam userId null + NotificationRead.
model Notification {
  id         String           @id @default(cuid())
  churchId   String           @map("church_id")
  type       NotificationType
  userId     String?          @map("user_id")
  title      String
  body       String?
  href       String?
  entityType String?          @map("entity_type")
  entityId   String?          @map("entity_id")
  payload    Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  expiresAt  DateTime?        @map("expires_at")
  readAt     DateTime?        @map("read_at")
  ackedAt    DateTime?        @map("acked_at")

  church Church             @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User?              @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  reads  NotificationRead[]

  @@index([churchId, userId, createdAt])
  @@index([churchId, type, entityId])
  @@index([expiresAt])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String   @map("notification_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}
