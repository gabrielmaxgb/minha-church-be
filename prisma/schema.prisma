generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChurchPermission {
  dashboard_access
  members_access
  ministries_access
  activities_access
  schedules_access
  members_manage
  ministries_manage
  events_create_church_wide
  finances_access
  communication_access
  reports_access
  settings_access
  roles_manage
  memberships_manage
  communication_manage
}

enum AnnouncementPriority {
  normal
  important
  urgent
}

enum AnnouncementAudienceType {
  church_wide
  ministries
}

enum ChurchPlanTier {
  starter
  small
  growth
  consolidated
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum MemberStatus {
  visitor
  active
  inactive
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum MaritalStatus {
  single
  married
  divorced
  widowed
}

enum PasswordResetRequestStatus {
  pending
  resolved
}

enum EventRecurrenceFrequency {
  daily
  weekly
  monthly
  yearly
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailCanonical       String    @unique @map("email_canonical")
  cpf                  String?   @unique
  passwordHash         String    @map("password_hash")
  name                 String
  avatarUrl            String?   @map("avatar_url")
  mustChangePassword   Boolean   @default(false) @map("must_change_password")
  temporaryPasswordEnc String?   @map("temporary_password_enc")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  memberships                   ChurchMembership[]
  memberProfiles                Member[]
  ministryEvents                MinistryEvent[]    @relation("EventCreatedBy")
  auditLogs                     AuditLog[]
  passwordResetTokens           PasswordResetToken[]
  emailVerificationTokens       EmailVerificationToken[]
  passwordResetRequests         PasswordResetRequest[]
  resolvedPasswordResetRequests PasswordResetRequest[] @relation("ResolvedPasswordResetRequests")
  announcements                 Announcement[]     @relation("AnnouncementAuthor")
  announcementReads             AnnouncementRead[]
  billingTierUpgradeAcknowledgments BillingTierUpgradeAcknowledgment[]
  billingTierUpgradeRequestsMade    BillingTierUpgradeRequest[]        @relation("BillingTierUpgradeRequestedBy")
  billingTierUpgradeRequestsResolved BillingTierUpgradeRequest[]       @relation("BillingTierUpgradeResolvedBy")
  billingTierUpgradeStaffNoticeReads BillingTierUpgradeStaffNoticeRead[]

  @@map("users")
}

model Church {
  id                     String               @id @default(cuid())
  name                   String
  slug                   String               @unique
  memberCount            Int                  @default(0) @map("member_count")
  planTier               ChurchPlanTier         @default(starter) @map("plan_tier")
  subscriptionStatus     SubscriptionStatus   @default(trialing) @map("subscription_status")
  trialEndsAt            DateTime?            @map("trial_ends_at")
  stripeCustomerId       String?              @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?              @map("stripe_subscription_id")
  stripePriceId          String?              @map("stripe_price_id")
  cancelAtPeriodEnd      Boolean              @default(false) @map("cancel_at_period_end")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  memberships           ChurchMembership[]
  members               Member[]
  ministries            Ministry[]
  roles                 ChurchRole[]
  auditLogs             AuditLog[]
  passwordResetRequests PasswordResetRequest[]
  announcements         Announcement[]

  billingTierUpgradeAcknowledgments BillingTierUpgradeAcknowledgment[]
  billingTierUpgradeRequests        BillingTierUpgradeRequest[]
  billingTierUpgradeStaffNotices    BillingTierUpgradeStaffNotice[]

  @@map("churches")
}

model BillingTierUpgradeAcknowledgment {
  id        String   @id @default(cuid())
  churchId  String   @map("church_id")
  tierId    String   @map("tier_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([churchId, tierId])
  @@map("billing_tier_upgrade_acknowledgments")
}

enum BillingTierUpgradeRequestStatus {
  pending
  approved
  dismissed
}

model BillingTierUpgradeRequest {
  id               String                          @id @default(cuid())
  churchId         String                          @map("church_id")
  targetTierId     String                          @map("target_tier_id")
  requestedByUserId String                         @map("requested_by_user_id")
  status           BillingTierUpgradeRequestStatus @default(pending)
  createdAt        DateTime                        @default(now()) @map("created_at")
  updatedAt        DateTime                        @updatedAt @map("updated_at")
  resolvedAt       DateTime?                       @map("resolved_at")
  resolvedByUserId String?                         @map("resolved_by_user_id")

  church      Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  requestedBy User   @relation("BillingTierUpgradeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  resolvedBy  User?  @relation("BillingTierUpgradeResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([churchId, targetTierId])
  @@index([churchId, status])
  @@map("billing_tier_upgrade_requests")
}

model BillingTierUpgradeStaffNotice {
  id        String   @id @default(cuid())
  churchId  String   @map("church_id")
  tierId    String   @map("tier_id")
  createdAt DateTime @default(now()) @map("created_at")

  church Church                            @relation(fields: [churchId], references: [id], onDelete: Cascade)
  reads  BillingTierUpgradeStaffNoticeRead[]

  @@index([churchId, createdAt])
  @@map("billing_tier_upgrade_staff_notices")
}

model BillingTierUpgradeStaffNoticeRead {
  id       String   @id @default(cuid())
  noticeId String   @map("notice_id")
  userId   String   @map("user_id")
  readAt   DateTime @default(now()) @map("read_at")

  notice BillingTierUpgradeStaffNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@map("billing_tier_upgrade_staff_notice_reads")
}

model StripeWebhookEvent {
  id          String   @id
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_webhook_events")
}

model ChurchRole {
  id           String   @id @default(cuid())
  churchId     String   @map("church_id")
  name         String
  color        String?
  sortOrder    Int      @default(0) @map("sort_order")
  isSystem     Boolean  @default(false) @map("is_system")
  systemKey    String?  @map("system_key")
  singleHolder Boolean  @default(false) @map("single_holder")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  church      Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  permissions ChurchRolePermission[]
  assignments ChurchMembershipRole[]

  @@unique([churchId, name])
  @@unique([churchId, systemKey])
  @@map("church_roles")
}

model ChurchRolePermission {
  roleId     String           @map("role_id")
  permission ChurchPermission

  role ChurchRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("church_role_permissions")
}

model ChurchMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  churchId  String   @map("church_id")
  isOwner   Boolean  @default(false) @map("is_owner")
  createdAt DateTime @default(now()) @map("created_at")

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church          Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  roleAssignments ChurchMembershipRole[]

  @@unique([userId, churchId])
  @@map("church_memberships")
}

model ChurchMembershipRole {
  membershipId String   @map("membership_id")
  roleId       String   @map("role_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  membership ChurchMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       ChurchRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("church_membership_roles")
}

model Member {
  id                 String         @id @default(cuid())
  churchId           String         @map("church_id")
  name               String
  email              String?
  cpf                String?
  phone              String?
  phoneSecondary     String?        @map("phone_secondary")
  birthDate          DateTime?      @map("birth_date") @db.Date
  gender             Gender?
  maritalStatus      MaritalStatus? @map("marital_status")
  weddingAnniversary DateTime?      @map("wedding_anniversary") @db.Date
  street             String?
  number             String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  zipCode            String?        @map("zip_code")
  status             MemberStatus   @default(visitor)
  visitorSince       DateTime?      @map("visitor_since") @db.Date
  baptismDate        DateTime?      @map("baptism_date") @db.Date
  membershipDate     DateTime?      @map("membership_date") @db.Date
  userId             String?        @map("user_id")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  church         Church              @relation(fields: [churchId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  ministryLinks  MemberMinistry[]
  availabilities EventAvailability[]
  eventRoleProfiles MemberEventRoleProfile[]
  rosterAssignments EventRosterAssignment[]

  @@unique([churchId, email])
  @@unique([churchId, cpf])
  @@unique([churchId, userId])
  @@index([churchId, status])
  @@map("members")
}

enum EventAvailabilityStatus {
  available
  unavailable
}

enum WorshipAvailabilityPeriod {
  weekly
  monthly
  quarterly
  semiannual
  annual
}

model Ministry {
  id          String            @id @default(cuid())
  churchId    String            @map("church_id")
  name        String
  description String?
  hasRoster   Boolean           @default(false) @map("has_roster")
  isActive    Boolean           @default(true) @map("is_active")
  availabilityWindowActive Boolean                   @default(false) @map("availability_window_active")
  availabilityPeriodType   WorshipAvailabilityPeriod? @map("availability_period_type")
  availabilityPeriodStart  DateTime?                  @map("availability_period_start") @db.Date
  availabilityPeriodEnd    DateTime?                  @map("availability_period_end") @db.Date
  serviceFunctionsUpdatedAt DateTime                  @default(now()) @map("service_functions_updated_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  church  Church           @relation(fields: [churchId], references: [id], onDelete: Cascade)
  roles   MinistryRole[]
  members MemberMinistry[]
  events  MinistryEvent[]
  eventRoleProfiles MemberEventRoleProfile[]
  serviceFunctions MinistryServiceFunction[]
  announcementTargets AnnouncementMinistry[]

  @@unique([churchId, name])
  @@map("ministries")
}

model MinistryServiceFunction {
  id         String   @id @default(cuid())
  ministryId String   @map("ministry_id")
  label      String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([ministryId, label])
  @@index([ministryId])
  @@map("ministry_service_functions")
}

model MemberEventRoleProfile {
  id         String   @id @default(cuid())
  memberId   String   @map("member_id")
  ministryId String   @map("ministry_id")
  profileKey String   @map("profile_key")
  roleLabels String[] @default([]) @map("role_labels")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@unique([memberId, ministryId, profileKey])
  @@index([memberId])
  @@map("member_event_role_profiles")
}

model MinistryRole {
  id              String   @id @default(cuid())
  ministryId      String   @map("ministry_id")
  name            String
  sortOrder       Int      @default(0) @map("sort_order")
  canManageEvents Boolean  @default(false) @map("can_manage_events")
  canManageRoster Boolean  @default(false) @map("can_manage_roster")
  canManageTeam   Boolean  @default(false) @map("can_manage_team")
  canManageRoles  Boolean  @default(false) @map("can_manage_roles")
  singleHolder    Boolean  @default(false) @map("single_holder")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  ministry    Ministry         @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  roleAssignments MemberMinistryRole[]

  @@unique([ministryId, name])
  @@map("ministry_roles")
}

model MemberMinistryRole {
  memberMinistryId String   @map("member_ministry_id")
  ministryRoleId   String   @map("ministry_role_id")
  assignedAt       DateTime @default(now()) @map("assigned_at")

  memberMinistry MemberMinistry @relation(fields: [memberMinistryId], references: [id], onDelete: Cascade)
  ministryRole   MinistryRole   @relation(fields: [ministryRoleId], references: [id], onDelete: Cascade)

  @@id([memberMinistryId, ministryRoleId])
  @@map("member_ministry_roles")
}

model MemberMinistry {
  id          String    @id @default(cuid())
  memberId    String    @map("member_id")
  ministryId  String    @map("ministry_id")
  instruments String[]  @default([])
  startedAt   DateTime? @map("started_at") @db.Date
  endedAt     DateTime? @map("ended_at") @db.Date
  serviceFunctionsCatalogSeenAt DateTime? @map("service_functions_catalog_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  member          Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  ministry        Ministry             @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  roleAssignments MemberMinistryRole[]

  @@unique([memberId, ministryId])
  @@map("member_ministries")
}

model EventRecurrenceSeries {
  id             String                   @id @default(cuid())
  churchId       String                   @map("church_id")
  ministryId     String?                  @map("ministry_id")
  frequency      EventRecurrenceFrequency
  interval       Int                      @default(1)
  daysOfWeek     Int[]                    @map("days_of_week")
  endDate        DateTime?                @map("end_date") @db.Date
  maxOccurrences Int?                     @map("max_occurrences")
  createdAt      DateTime                 @default(now()) @map("created_at")

  events MinistryEvent[]

  @@index([churchId])
  @@map("event_recurrence_series")
}

model MinistryEvent {
  id                   String    @id @default(cuid())
  churchId             String    @map("church_id")
  ministryId           String?   @map("ministry_id")
  name                 String
  description          String?
  highlightNote        String?   @map("highlight_note")
  availabilityMessage  String?   @map("availability_message")
  location             String?
  startsAt             DateTime  @map("starts_at")
  endsAt               DateTime? @map("ends_at")
  createdByUserId      String?   @map("created_by_user_id")
  recurrenceSeriesId   String?   @map("recurrence_series_id")
  usesRoster           Boolean   @default(true) @map("uses_roster")
  rosterOpen           Boolean   @default(false) @map("roster_open")
  visibleToChurch      Boolean   @default(true) @map("visible_to_church")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  ministry         Ministry?              @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy        User?                  @relation("EventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  recurrenceSeries EventRecurrenceSeries? @relation(fields: [recurrenceSeriesId], references: [id], onDelete: SetNull)
  availabilities   EventAvailability[]
  rosterSlots      EventRosterSlot[]
  rosterAssignments EventRosterAssignment[]

  @@index([churchId, ministryId, startsAt])
  @@index([churchId, startsAt])
  @@index([recurrenceSeriesId])
  @@map("ministry_events")
}

model EventAvailability {
  id         String                  @id @default(cuid())
  eventId    String                  @map("event_id")
  memberId   String                  @map("member_id")
  status     EventAvailabilityStatus
  roleLabels String[]                @default([]) @map("role_labels")
  createdAt  DateTime                @default(now()) @map("created_at")
  updatedAt  DateTime                @updatedAt @map("updated_at")

  event  MinistryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@index([memberId])
  @@map("event_availabilities")
}

model EventRosterSlot {
  id            String   @id @default(cuid())
  eventId       String   @map("event_id")
  label         String
  requiredCount Int      @default(1) @map("required_count")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  event       MinistryEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments EventRosterAssignment[]

  @@unique([eventId, label])
  @@index([eventId])
  @@map("event_roster_slots")
}

model EventRosterAssignment {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  memberId     String   @map("member_id")
  rosterSlotId String?  @map("roster_slot_id")
  roleLabel    String   @map("role_label")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event      MinistryEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rosterSlot EventRosterSlot? @relation(fields: [rosterSlotId], references: [id], onDelete: SetNull)

  @@unique([eventId, memberId])
  @@index([eventId, rosterSlotId])
  @@index([memberId])
  @@map("event_roster_assignments")
}

model AuditLog {
  id          String   @id @default(cuid())
  churchId    String   @map("church_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([churchId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([churchId, action])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetRequest {
  id               String                     @id @default(cuid())
  userId           String                     @map("user_id")
  churchId         String                     @map("church_id")
  status           PasswordResetRequestStatus @default(pending)
  createdAt        DateTime                   @default(now()) @map("created_at")
  resolvedAt       DateTime?                  @map("resolved_at")
  resolvedByUserId String?                    @map("resolved_by_user_id")

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church     Church @relation(fields: [churchId], references: [id], onDelete: Cascade)
  resolvedBy User?  @relation("ResolvedPasswordResetRequests", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([churchId, status])
  @@index([userId, churchId, status])
  @@map("password_reset_requests")
}

model Announcement {
  id              String                   @id @default(cuid())
  churchId        String                   @map("church_id")
  title           String
  body            String
  priority        AnnouncementPriority     @default(normal)
  audienceType    AnnouncementAudienceType @default(church_wide) @map("audience_type")
  pinned          Boolean                  @default(false)
  publishedAt     DateTime?                @map("published_at")
  expiresAt       DateTime?                @map("expires_at")
  createdByUserId String?                  @map("created_by_user_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  deletedAt       DateTime?                @map("deleted_at")

  church     Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  createdBy  User?                  @relation("AnnouncementAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  ministries AnnouncementMinistry[]
  reads      AnnouncementRead[]

  @@index([churchId, deletedAt, publishedAt])
  @@map("announcements")
}

model AnnouncementMinistry {
  announcementId String @map("announcement_id")
  ministryId     String @map("ministry_id")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  ministry     Ministry     @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@id([announcementId, ministryId])
  @@index([ministryId])
  @@map("announcement_ministries")
}

model AnnouncementRead {
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
  @@index([userId])
  @@map("announcement_reads")
}
